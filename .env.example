# NeuroSync — Environment Variables
# Copy this file to .env and fill in your keys.

# ══════════════════════════════════════════════════════════════════════════════
#  AI PROVIDER — Groq (required)
# ══════════════════════════════════════════════════════════════════════════════
#
#   1. Go to https://console.groq.com
#   2. Sign up (free, no credit card)
#   3. Create an API key under "API Keys"
#
#   Used for: chat, behavior interpretation, reports, handwriting analysis
#   (vision via meta-llama/llama-4-scout-17b-16e-instruct for handwriting)
#
GROQ_API_KEY=your_groq_api_key_here
# GROQ_MODEL=llama-3.3-70b-versatile   # default
# GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct   # optional vision model for handwriting

# ══════════════════════════════════════════════════════════════════════════════
#  DATABASE
# ══════════════════════════════════════════════════════════════════════════════

# SQLite path (default: ./neurosync.db)
# DB_PATH=/data/neurosync.db

# ══════════════════════════════════════════════════════════════════════════════
#  AUDIO FILE STORAGE
# ══════════════════════════════════════════════════════════════════════════════
# Where uploaded audio recordings are saved on disk.
# Clips are auto-deleted after 30 days (DPDP §8 retention).
# Default: ./uploads
#
# UPLOADS_DIR=/data/uploads

# ══════════════════════════════════════════════════════════════════════════════
#  ML SIDECAR — Python FastAPI (local, strongly recommended)
# ══════════════════════════════════════════════════════════════════════════════
# Provides real MFCC audio embeddings via librosa + ffmpeg.
# Falls back to a JS approximation if unreachable.
#
# Setup (one-time, Python 3.10+):
#   cd ml
#   python -m venv .venv
#   .venv\Scripts\activate        # Windows
#   source .venv/bin/activate     # Mac/Linux
#   pip install -r requirements.txt
#
# Start alongside Node:
#   npm run dev:full              # starts both Node + sidecar together
#
# Requires ffmpeg installed system-wide (winget install Gyan.FFmpeg on Windows)
#
ML_SIDECAR_URL=http://localhost:8000

# Path to ffmpeg binary — only needed if ffmpeg is not on PATH
# FFMPEG_PATH=C:\Users\YourName\AppData\Local\Microsoft\WinGet\Links\ffmpeg.exe

# ══════════════════════════════════════════════════════════════════════════════
#  MULTILINGUAL — Bhashini (India GOI, optional)
# ══════════════════════════════════════════════════════════════════════════════
# Leave unset for English-only mode (safe default).
# Register at: https://bhashini.gov.in/ulca
#
# BHASHINI_API_KEY=your_bhashini_key
# BHASHINI_ENDPOINT=https://dhruva-api.bhashini.gov.in/services/inference/pipeline

# ══════════════════════════════════════════════════════════════════════════════
#  EMAIL — Resend (optional, for sending reports by email)
# ══════════════════════════════════════════════════════════════════════════════
# Free tier: 3,000 emails/month — https://resend.com
#
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ══════════════════════════════════════════════════════════════════════════════
#  YOUTUBE DATA API v3 (optional, for lesson video thumbnails)
# ══════════════════════════════════════════════════════════════════════════════
# Used by the Lesson Planner to show relevant YouTube video thumbnails per step.
# Key is stored server-side ONLY — never sent to the browser.
#
# Setup:
#   1. Go to https://console.cloud.google.com
#   2. Create a project → Enable "YouTube Data API v3"
#   3. Create an API key (restrict to YouTube Data API v3)
#   Free tier: 10,000 units/day — each search costs 100 units.
#   Results are cached for 24h per topic+difficulty, so real usage is minimal.
#
# YOUTUBE_API_KEY=AIza...

# ══════════════════════════════════════════════════════════════════════════════
#  SERVER
# ══════════════════════════════════════════════════════════════════════════════
# PORT=3000
# NODE_ENV=production
