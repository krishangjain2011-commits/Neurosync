{
  "name": "neurosync",
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build",
    "start": "node --import tsx/esm server.ts",
    "start:prod": "NODE_ENV=production node --import tsx/esm server.ts",
    "ml:start": "ml\\.venv\\Scripts\\uvicorn.exe main:app --app-dir ml --host 0.0.0.0 --port 8000",
    "handwriting:start": "cd handwriting-service && ..\\ml\\.venv\\Scripts\\python.exe -m uvicorn app.main:app --host 0.0.0.0 --port 8001",
    "ml:setup": "python -m venv ml\\.venv && ml\\.venv\\Scripts\\pip.exe install -r ml\\requirements.txt",
    "dev:full": "concurrently --names \"app,ml\" --prefix-colors \"cyan,yellow\" --kill-others-on-fail \"npm run dev\" \"npm run ml:start\"",
    "dev:full-handwriting": "concurrently --names \"app,ml,hw\" --prefix-colors \"cyan,yellow,magenta\" --kill-others-on-fail \"npm run dev\" \"npm run ml:start\" \"npm run handwriting:start\""
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@google/genai": "^1.3.0",
    "@tailwindcss/vite": "^4.0.0",
    "@vitejs/plugin-react": "^4.4.1",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.11.1",
    "connect-sqlite3": "^0.9.15",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.1",
    "express-session": "^1.18.1",
    "firebase": "^12.16.0",
    "firebase-admin": "^14.2.0",
    "form-data": "^4.0.1",
    "framer-motion": "^11.15.0",
    "groq-sdk": "^1.3.0",
    "jose": "^5.10.0",
    "multer": "^2.0.1",
    "nodemailer": "^6.10.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "recharts": "^2.13.3",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "vite": "^6.0.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/connect-sqlite3": "^0.9.5",
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.18.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/nodemailer": "^6.1.0",
    "concurrently": "^9.1.2",
    "typescript": "^5.7.2"
  }
}
