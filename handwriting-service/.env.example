# Handwriting Service Environment Variables
# This is a microservice that provides vision-based handwriting analysis.
# It connects to Mistral's vision-capable models for image understanding.

# ═══════════════════════════════════════════════════════════════════════════════
#  MISTRAL API KEY (REQUIRED)
# ═══════════════════════════════════════════════════════════════════════════════
# Use the same Mistral API key as your Mistral account.
#
# Setup:
#   1. Go to https://console.mistral.ai/
#   2. Create or reuse an API key
#   3. Paste the same key here
#
MISTRAL_API_KEY=your_mistral_api_key_here

# ═══════════════════════════════════════════════════════════════════════════════
#  CORS Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# URLs allowed to call this service (from Node app)
# Development: single URL
# Production: comma-separated list
#
ALLOWED_ORIGINS=http://localhost:3000
HANDWRITING_FALLBACK_MODE=true
